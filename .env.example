# Copy this file to `.env` and fill in your own values.
# NEVER commit your real .env — it is gitignored for a reason.

# Deployer private key (used by scripts/deploy.js). KEEP THIS SECRET.
PRIVATE_KEY=

# RPC endpoints
POLYGON_RPC_URL=https://polygon-rpc.com
AMOY_RPC_URL=https://rpc-amoy.polygon.technology

# Polygonscan API key (for `npx hardhat verify`)
POLYGONSCAN_API_KEY=
